# ─────────────────────────────────────────────────────
# دقة قلم — متغيرات البيئة
# انسخ هذا الملف إلى .env وعدّل القيم
# ─────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production

# ── Security ──────────────────────────────────────────
# مفتاح API لحماية نقاط CNC والعمليات الحساسة
# أنشئ قيمة عشوائية قوية: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET_KEY=

# النطاقات المسموح لها بالوصول (افصل بفاصلة)
# اتركها فارغة للسماح للكل في وضع التطوير
ALLOWED_ORIGINS=https://diqqatqalam.com

# ── Anthropic Claude AI ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase Auth (اختياري) ───────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# مفتاح service_role (سرّي — للخادم فقط، لا يُرسل للعميل أبداً).
# مطلوب لِديمومة الاشتراكات والدفعات عبر نسخ الدالة (serverless). بدونه تُحفظ
# الاشتراكات/الدفعات في ملف مؤقّت وتضيع، ولا تتم ترقية من يدفع.
# Supabase → Project Settings → API → service_role secret
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── الدفع — العراق ────────────────────────────────────
# الرابط العام للخادم (مطلوب لروابط الـ callback من مزودي الدفع)
PUBLIC_BASE_URL=https://diqqatqalam.com

# FIB (First Iraqi Bank) — احصل على الحساب التجاري من https://fib.iq/business
# بيئة الاختبار: https://fib.stage.fib.iq — الإنتاج: https://fib.prod.fib.iq
FIB_BASE_URL=https://fib.stage.fib.iq
FIB_CLIENT_ID=
FIB_CLIENT_SECRET=

# Visa / Mastercard عبر PayTabs العراق — https://site.paytabs.com/iq
PAYTABS_BASE_URL=https://secure-iraq.paytabs.com
PAYTABS_PROFILE_ID=
PAYTABS_SERVER_KEY=
PAYTABS_CURRENCY=IQD

# Zain Cash (WaaS API) — https://zaincash.iq/developers
# بيئة الاختبار: https://test.zaincash.iq — الإنتاج: https://api.zaincash.iq
ZAINCASH_BASE_URL=https://test.zaincash.iq
ZAINCASH_MERCHANT_ID=
ZAINCASH_SECRET=
ZAINCASH_MSISDN=9647XXXXXXXXX

# ── إشعارات تيليجرام (#17) ────────────────────────────
# أنشئ بوت عبر @BotFather واحصل على الـ token، ثم راسِل بوتك رسالة واحدة
# واكتشف chat_id عبر: GET /api/notify/telegram/chat-id (يحتاج X-API-Key)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── رابط تحميل تطبيق سطح المكتب ─────────────────────
# ارفع DiqqatQalam-Setup-*.exe كـ GitHub Release ثم ضع رابط التحميل المباشر هنا
# مثال: https://github.com/yourname/diqqat-qalam/releases/download/v2.0.0/DiqqatQalam-Setup-2.0.0.exe
DOWNLOAD_URL=
