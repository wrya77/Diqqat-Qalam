{
  "name": "diqqat-qalam",
  "version": "2.0.0",
  "description": "دقة قلم — مولّد G-Code الاحترافي لآلات CNC",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js --ignore uploads/ --ignore exports/",
    "test": "jest --coverage --forceExit",
    "test:watch": "jest --watch",
    "build": "node scripts/generate-all-files.js",
    "setup": "npm install && node scripts/generate-all-files.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@supabase/supabase-js": "^2.107.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsdom": "^24.1.3",
    "multer": "^2.1.1",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ]
  }
}
