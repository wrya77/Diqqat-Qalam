{
  "name": "diqqat-qalam",
  "version": "1.0.0",
  "description": "دقة قلم — مولّد G-Code الاحترافي لآلات CNC",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js --ignore uploads/ --ignore exports/",
    "test": "jest --coverage --forceExit",
    "test:watch": "jest --watch",
    "build": "node scripts/generate-all-files.js",
    "setup": "npm install && node scripts/generate-all-files.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "serialport": "^13.0.0",
    "socket.io": "^4.7.2",
    "xmldom": "^0.1.31"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jsdom": "^24.0.0",
    "nodemon": "^3.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ]
  }
}
